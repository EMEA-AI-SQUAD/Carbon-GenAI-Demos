var defaults = { 
	free_form_text: "The name of our next book is The Hunger Games. Now, some of you might have read this book earlier, but in my personal opinion, reading it again won't hurt, right? It gets even more interesting when we read it a second time. So, the author of this book is Suzanne Collins, who wrote many books in the past, but this particular book for her has got a rating of 4.33/5, which I think is a pretty good number considering what we just saw for The Book Thief. Anyways, this book is a work of fiction, written in English and falls in the Post Apocalyptic genre. This book has 374 pages. It was published on the 10th of October, 2005. This book is priced at 5 dollars and 9 cents. If anyone is interested in this book, you can approach Mr Hofstadter after this workshop, he will be glad to sell you this book for only 3 dollars. Dont miss out this chance to grab such a memorable book.",
	label1: "Title",
	definition1: "This is the title of the book.",
	

function MultiText({ defaults }) {
  // `defaults` is an object like:
  // { summary: '...', notes: '...', excerpt: '...' }

  const [values, setValues] = useState(defaults);

  // Keep state in sync if the parent changes `defaults`
  useEffect(() => {
    setValues(defaults);
  }, [defaults]);

  // Single change handler for all fields
  const handleChange = (name) => (e) => {
    const next = e.target.value;
    setValues((prev) => ({ ...prev, [name]: next }));
  };


export default function EntityExtractionPage() {
let slot_id = -1;

const API_URL = 'http://p1270-pvm1.p1270.cecc.ihost.com:3001';

const openai_client = new OpenAI({
    baseURL: API_URL,  // Fixed: removed quotes, changed to baseURL
    apiKey: 'sk-no-key-required',
    dangerouslyAllowBrowser: true
});

var text_about_book = "The name of our next book is The Hunger Games. Now, some of you might have read this book earlier, but in my personal opinion, reading it again won't hurt, right? It gets even more interesting when we read it a second time. So, the author of this book is Suzanne Collins, who wrote many books in the past, but this particular book for her has got a rating of 4.33/5, which I think is a pretty good number considering what we just saw for The Book Thief. Anyways, this book is a work of fiction, written in English and falls in the Post Apocalyptic genre. This book has 374 pages. It was published on the 10th of October, 2005. This book is priced at 5 dollars and 9 cents. If anyone is interested in this book, you can approach Mr Hofstadter after this workshop, he will be glad to sell you this book for only 3 dollars. Dont miss out this chance to grab such a memorable book."
console.log(text_about_book)

async function completion() {
  console.log("Calling LLM...");
  console.log("API URL:", API_URL)
  try {
    const result = await openai_client.chat.completions.create({
      model: 'gpt-3.5-turbo',  // llama.cpp ignores this but needs it
      messages: [
        { role: 'system', content: 'You are a coding assistant that talks like a pirate' },
        { role: 'user', content: 'Are semicolons optional in JavaScript?' }
      ],
      stream: true,
    });

    for await (const chunk of result) {
      const content = chunk.choices[0]?.delta?.content;
      if (content) {
        console.log(content);
      }
    }
  } catch (error) {
    console.error('Error calling LLM:', error);
  }
}

